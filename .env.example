# ============================================
# CONFIGURACIÓN PARA NETLIFY
# ============================================

# Base de datos (Turso - SQLite en la nube, GRATIS)
# Obtén tu base de datos en: https://turso.tech
DATABASE_URL="libsql://tu-base-de-datos.turso.io?authToken=tu-auth-token"
DIRECT_DATABASE_URL="libsql://tu-base-de-datos.turso.io?authToken=tu-auth-token"

# Alternativa: Neon (PostgreSQL serverless, GRATIS)
# Obtén tu base de datos en: https://neon.tech
# DATABASE_URL="postgresql://usuario:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_DATABASE_URL="postgresql://usuario:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ============================================
# CONFIGURACIÓN LOCAL (desarrollo)
# ============================================
# Para desarrollo local con SQLite:
# DATABASE_URL="file:./prisma/dev.db"
